# copy and rename this file to .env and add your actual environment variables

# AI-Assistant Server Configuration
# URL for the AI-Assistant signaling server.
#
# Local development (HTTP, no authentication):
#   AI_ASSISTANT_SERVER_URL=localhost:8080
#   AI_ASSISTANT_SERVER_URL=http://localhost:8080
#   AI_ASSISTANT_SERVER_URL=10.0.2.2:8080   # Android emulator → host machine
#
# Cloud Run (HTTPS, Firebase ID token required):
#   AI_ASSISTANT_SERVER_URL=https://ai-assistant-xxxx-ey.a.run.app
#
# The app automatically detects the scheme:
#   https:// → wss:// + Firebase ID token sent as Authorization: Bearer
#   http:// or bare host:port → ws:// (no auth token)
AI_ASSISTANT_SERVER_URL=localhost:8080

# Google OAuth Client ID (for Firebase Authentication on Android and backend validation)
# This is the Web client ID from Firebase Console → Authentication → Google Sign-in
# Format: XXXXXX-xxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID=your-web-client-id-here.apps.googleusercontent.com

# Set to false when connecting to a lite-mode (text-only) server deployment.
# Controls which feature set the app activates. Must match the server-side
# AGENT_MODE value. Use "full" for a deployment with voice + text + all features,
# or "lite" for a text-only deployment (skips voice pre-warm and TTS warmup).
APP_MODE=full

# Firestore named database (must match FIRESTORE_DATABASE_NAME in ai-assistant/.env)
# Use (default) for production, or the named database for local dev
FIRESTORE_DATABASE_NAME=(default)

# Web server port for the ConnectX client application
WEB_PORT=60099