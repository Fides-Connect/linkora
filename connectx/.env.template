# copy and rename this file to .env and fill in your actual values

# ══════════════════════════════════════════════════════════════════
# General — required in all modes
# ══════════════════════════════════════════════════════════════════

# App mode (full | lite) — must match the server-side AGENT_MODE value.
# full: voice + text, provider pitch, onboarding, all features enabled.
# lite: text-only chat, Google Places provider search, no Firestore.
APP_MODE=full

# AI-Assistant server URL.
#
# Local development (HTTP, no authentication):
#   AI_ASSISTANT_SERVER_URL=localhost:8080
#   AI_ASSISTANT_SERVER_URL=http://localhost:8080
#   AI_ASSISTANT_SERVER_URL=10.0.2.2:8080   # Android emulator → host machine
#
# Cloud Run (HTTPS, Firebase ID token required):
#   AI_ASSISTANT_SERVER_URL=https://ai-assistant-xxxx-ey.a.run.app
#
# The app automatically detects the scheme:
#   https:// → wss:// + Firebase ID token sent as Authorization: Bearer
#   http:// or bare host:port → ws:// (no auth token)
AI_ASSISTANT_SERVER_URL=localhost:8080

# Google OAuth Web Client ID (for Firebase Authentication on Android).
# Find this in Firebase Console → Authentication → Sign-in method → Google.
# Format: XXXXXX-xxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID=your-web-client-id-here.apps.googleusercontent.com


# ══════════════════════════════════════════════════════════════════
# Full Mode only  (APP_MODE=full)
# ══════════════════════════════════════════════════════════════════

# Firestore named database — must match FIRESTORE_DATABASE_NAME in ai-assistant/.env.
# Use "(default)" for production or the named database for local development.
FIRESTORE_DATABASE_NAME=(default)
