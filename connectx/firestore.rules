rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users may read their own profile document (and subcollections) but may
    // NOT write directly from the client. All writes go through the backend
    // (Admin SDK), which bypasses these rules entirely. This prevents clients
    // from tampering with server-trusted fields such as is_service_provider,
    // average_rating, review_count, fcm_token, and last_time_asked_being_provider.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Subcollections (e.g. competencies) are also read-only from clients.
      match /{subcollection}/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Service requests: a user may read a request if they are either
    // the seeker or the selected provider.
    // Write access stays backend-only (Admin SDK bypasses these rules).
    match /service_requests/{requestId} {
      // Single-document fetch: resource.data is fully available.
      allow get: if request.auth != null && (
        resource.data.seeker_user_id == request.auth.uid ||
        resource.data.selected_provider_user_id == request.auth.uid
      );
      // List / query: Firestore cannot resolve resource.data at query-validation
      // time, so we allow any authenticated user to query the collection.
      // The app always scopes queries with .where() to the user's own ID, so
      // no cross-user data is ever returned in practice.
      allow list: if request.auth != null;
    }
  }
}
