# copy and rename this file to .env and add your actual environment variables

# AI-Assistant Server Configuration
# URL for the AI-Assistant signaling server
# Default: localhost:8080 (for local development)
# For production, use your deployed server URL: your-server-ip:8080
AI_ASSISTANT_SERVER_URL=localhost:8080

# Google OAuth Client ID (for Google Sign-In validation)
GOOGLE_OAUTH_CLIENT_ID=591958549747-nkidmceuchso2acbc46l8ls8h7g01h1e.apps.googleusercontent.com

# Web server port for the ConnectX client application
WEB_PORT=60099