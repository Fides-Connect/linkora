{
  "name": "Flutter Development",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "runArgs": [
    // "--privileged",
    // "--network=host",
    "--init"
  ],
  "forwardPorts": [
    8080,
    3000,
    5000,
    5001,
    8000,
    9000
  ],
  "portsAttributes": {
    "8080": {
      "label": "Flutter Web Dev Server",
      "onAutoForward": "notify"
    },
    "3000": {
      "label": "Flutter Web Hot Reload",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter",
        "ms-vscode.vscode-json",
        "bradlc.vscode-tailwindcss",
        "usernamehw.errorlens",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-typescript-next",
        "formulahendry.auto-rename-tag",
        "ms-vscode.hexdump",
        "ms-toolsai.jupyter",
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ],
      "settings": {
        "dart.flutterSdkPath": "/opt/flutter",
        "dart.sdkPath": "/opt/flutter/bin/cache/dart-sdk",
        "dart.checkForSdkUpdates": false,
        "dart.openDevTools": "flutter",
        "dart.previewFlutterUiGuides": true,
        "dart.previewFlutterUiGuidesCustomTracking": true,
        "flutter.forceWebRenderer": "html",
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/bin/bash"
          }
        },
        "java.home": "/usr/lib/jvm/java-17-openjdk-arm64"
      }
    }
  },
  "postCreateCommand": "flutter doctor --android-licenses || true && flutter doctor",
  "remoteUser": "vscode",
  "containerEnv": {
    "FLUTTER_ROOT": "/opt/flutter",
    "ANDROID_HOME": "/opt/android-sdk",
    "ANDROID_SDK_ROOT": "/opt/android-sdk",
    "PATH": "/opt/flutter/bin:/opt/android-sdk/cmdline-tools/latest/bin:/opt/android-sdk/platform-tools:${containerEnv:PATH}",
    "CHROME_EXECUTABLE": "/usr/bin/chromium-browser"
  },
  "workspaceFolder": "/workspace"
}