FROM python:3.11-slim

# Install system dependencies and nginx + supervisor
RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    libssl-dev \
    pkg-config \
    libopus-dev \
    libvpx-dev \
    libsrtp2-dev \
    nginx \
    supervisor \
    openssl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy requirements first for better caching
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy application source code
COPY src/ ./src/
COPY main.py .

# Copy nginx config into the image
COPY configs/nginx.conf /etc/nginx/sites-available/ai-assistant
RUN mkdir -p /etc/nginx/sites-enabled && rm -f /etc/nginx/sites-enabled/default \
    && ln -sf /etc/nginx/sites-available/ai-assistant /etc/nginx/sites-enabled/ai-assistant

# Copy supervisord config into the image
COPY configs/supervisor.conf /etc/supervisor/conf.d/supervisor.conf

# Copy self-signed SSL certificate
COPY secrets/ssl-cert.pem /etc/ssl/ai-assistant/ssl-cert.pem
COPY secrets/ssl-key.pem /etc/ssl/ai-assistant/ssl-key.pem

# Expose HTTP / HTTPS and app port (for direct testing)
EXPOSE 80 443 8080

# Set environment variables
ENV PYTHONUNBUFFERED=1

# Start supervisord which runs nginx + python app
CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/conf.d/supervisor.conf"]