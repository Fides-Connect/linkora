# Google Cloud Configuration
# Local filename of your Google Cloud service account JSON file (in ai-assistant directory)
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=your-service-account-key.json

# Gemini API Key (used for LLM and embeddings via LangChain)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use
GEMINI_MODEL=gemini-2.5-flash

# Firestore Database Configuration
# Specify which Firestore database to use (e.g., "development", "production")
# This database need to be created in your Firestore instance beforehand. If not set, defaults to "(default)" database.
FIRESTORE_DATABASE_NAME=(default)

# Weaviate Configuration
# 
# Option 1: Local/Self-hosted Weaviate (for development) - DEFAULT
# Set WEAVIATE_URL to your local Weaviate instance
WEAVIATE_URL=http://localhost:8090
#
# Option 2: Weaviate Cloud Services (for production)
# Set WEAVIATE_CLUSTER_URL and WEAVIATE_API_KEY (leave WEAVIATE_URL as-is or commented)
# WEAVIATE_CLUSTER_URL=https://your-cluster.weaviate.network
# WEAVIATE_API_KEY=your-weaviate-cloud-api-key
#
# Note: If both WEAVIATE_CLUSTER_URL and WEAVIATE_API_KEY are set, 
# cloud deployment takes precedence over local WEAVIATE_URL

# Language and Voice Configuration
# German configuration
LANGUAGE_CODE_DE=de-DE
VOICE_NAME_DE=de-DE-Chirp3-HD-Sulafat
# English configuration
LANGUAGE_CODE_EN=en-US
VOICE_NAME_EN=en-US-Chirp3-HD-Sulafat

# Server Configuration
HOST=0.0.0.0
PORT=8080

# Logging Level
LOG_LEVEL=INFO

# Number of concurrent requests to Google TTS API
GOOGLE_TTS_API_CONCURRENCY=5

# Debug: Record received audio to WAV files (true/false)
DEBUG_RECORD_AUDIO=false

# Admin Panel Configuration
# Generate a secure token using: python -c "import secrets; print(secrets.token_urlsafe(32))"
# This token is required to access admin endpoints for debugging and deployment management
ADMIN_SECRET_KEY=your_secure_admin_token_here
