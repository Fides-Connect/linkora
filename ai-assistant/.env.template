# copy and rename this file to .env and fill in your actual values

# ══════════════════════════════════════════════════════════════════
# General — required in all modes
# ══════════════════════════════════════════════════════════════════

# Agent Mode (full | lite)
# full: all features — voice, provider pitch, provider onboarding, all REST endpoints
# lite: text-only WebSocket chat, Google Places provider search, no Firestore writes
# Defaults to "full" if unset.
AGENT_MODE=full

# Gemini API Key (LLM for all response generation and tool calls)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use
GEMINI_MODEL=gemini-2.5-flash

# Server configuration
HOST=0.0.0.0
PORT=8080

# Logging level (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Admin Panel — generate a secure token via:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Required to access admin endpoints for debugging and deployment management.
ADMIN_SECRET_KEY=your_secure_admin_token_here


# ══════════════════════════════════════════════════════════════════
# Full Mode only  (AGENT_MODE=full)
# ══════════════════════════════════════════════════════════════════

# Firestore Database
# Specifies which Firestore database to use (e.g. "development", "production").
# Must be created in your Firestore instance beforehand.
# Defaults to "(default)" if unset.
FIRESTORE_DATABASE_NAME=(default)

# Weaviate — provider vector / hybrid search index
#
# Option 1: Local / self-hosted (development default)
WEAVIATE_URL=http://localhost:8090
#
# Option 2: Weaviate Cloud Services (production)
# When both variables below are set they take precedence over WEAVIATE_URL.
# WEAVIATE_CLUSTER_URL=https://your-cluster.weaviate.network
# WEAVIATE_API_KEY=your-weaviate-cloud-api-key

# Re-sync Weaviate from Firestore on startup (true | false)
WEAVIATE_SYNC_ON_STARTUP=false

# Language and Voice — Text-to-Speech voices used in voice sessions
LANGUAGE_CODE_DE=de-DE
VOICE_NAME_DE=de-DE-Chirp3-HD-Sulafat
LANGUAGE_CODE_EN=en-US
VOICE_NAME_EN=en-US-Chirp3-HD-Sulafat

# Maximum concurrent requests to the Google TTS API
GOOGLE_TTS_API_CONCURRENCY=5

# Debug: record received audio to WAV files (true | false)
DEBUG_RECORD_AUDIO=false


# ══════════════════════════════════════════════════════════════════
# Lite Mode only  (AGENT_MODE=lite)
# ══════════════════════════════════════════════════════════════════

# Google Places API Key — required in lite mode
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Maximum number of results fetched from the Google Places API per search.
# The API returns up to 20 results per page and supports at most 3 pages,
# so the effective maximum is 60. Values above 60 are clamped to 60.
# Lower values reduce latency and LLM/API cost at the expense of result diversity.
GP_MAX_RESULTS=60

# Enable or disable webpage crawling for Google Places results (true | false).
# When enabled, the system visits each provider's website to extract additional
# information (specialities, services, contact email) for richer provider cards
# and improved search ranking. Disabling this reduces latency and LLM token usage.
GP_WEBPAGE_CRAWL_ENABLED=true
